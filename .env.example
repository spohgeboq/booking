# ============================================
# Переменные окружения для Docker Compose
# Скопируйте этот файл в .env и заполните значения
# cp .env.example .env
# ============================================

# --- База данных PostgreSQL ---
POSTGRES_USER=booking_user
POSTGRES_PASSWORD=ЗАМЕНИТЕ_НА_СЛОЖНЫЙ_ПАРОЛЬ_32_СИМВОЛА
POSTGRES_DB=booking_db

# --- Backend ---
JWT_SECRET=ЗАМЕНИТЕ_НА_СЛУЧАЙНЫЙ_СЕКРЕТ_64_СИМВОЛА
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_GROUP_ID=your_telegram_group_id
BACKEND_PUBLIC_URL=http://your-domain.com

# --- Frontend Build Args ---
# URL бэкенда для booking-frontend (через прокси — относительный путь)
VITE_BOOKING_BACKEND_URL=
# URL бэкенда для admin-panel (через прокси — относительный путь)
VITE_ADMIN_BACKEND_URL=
# URL клиентского сайта (для ссылок из админки)
VITE_CLIENT_URL=http://your-domain.com
# URL админки (для ссылок с клиентского сайта)
VITE_ADMIN_URL=http://your-domain.com:8080
